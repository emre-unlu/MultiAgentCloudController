# Chroma MCP client configuration
# Uses: uvx chroma-mcp --client-type persistent --data-dir ./.chroma
CHROMA_MCP_COMMAND=uvx
CHROMA_MCP_ARGS="chroma-mcp --client-type persistent --data-dir ./.chroma"
CHROMA_MCP_COLLECTION=incident_history

# Kubernetes MCP client configuration
KUBERNETES_MCP_COMMAND=poetry
KUBERNETES_MCP_ARGS="run python main.py"
KUBERNETES_MCP_REPO_PATH=/absolute/path/to/Kubernetes-Mcp
