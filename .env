# ------------------------------------------------------------------
# OpenAI / LLM configuration
# ------------------------------------------------------------------
OPENAI_API_KEY=""
OPENAI_PROJECT_ID=""
OPENAI_MODEL="gpt-5-mini"

# Optional tracing / observability for development
LANGSMITH_TRACING="false"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="multi-agent-cloud-controller"

# ------------------------------------------------------------------
# Chroma MCP client configuration
# Example:
#   run python -m chroma_mcp.cli --client-type persistent --data-dir ./.chroma
# ------------------------------------------------------------------
CHROMA_MCP_COMMAND=python
CHROMA_MCP_ARGS="-m chroma_mcp.cli --client-type persistent --data-dir ./.chroma"
CHROMA_MCP_COLLECTION=incident_history
CHROMA_MCP_CWD=C:\github\MultiAgentCloudController

# ------------------------------------------------------------------
# Kubernetes MCP client configuration
# Example:
#   poetry run python main.py
# executed inside the Kubernetes-Mcp repository
# ------------------------------------------------------------------
KUBERNETES_MCP_COMMAND=C:\Users\iemre\AppData\Local\pypoetry\Cache\virtualenvs\kubernetes-mcp-1uln4EDn-py3.14\Scripts\python.exe
KUBERNETES_MCP_ARGS=main.py
KUBERNETES_MCP_REPO_PATH=C:\github\Kubernetes-Mcp

# ------------------------------------------------------------------
# Workflow / agent budgets
# ------------------------------------------------------------------
MAX_DIAGNOSIS_ATTEMPTS="2"

INFORMATION_MAX_TOOL_CALLS="2"
DETECTION_LITE_MAX_TOOL_CALLS="2"
DIAGNOSIS_MAX_TOOL_CALLS="5"
SUPERVISOR_MAX_TOOL_CALLS="2"

# Optional overall safety limit
MAX_DAILY_OPENAI_TOKEN_LIMIT="2000000"

# ------------------------------------------------------------------
# Default cluster / environment context
# ------------------------------------------------------------------
DEFAULT_CLUSTER_NAME="demo-cluster"
DEFAULT_NAMESPACE="default"
DEFAULT_ENVIRONMENT="local-dev"

# Optional investigation hints
TRACE_SERVICE_STARTING_POINT="frontend"

# ------------------------------------------------------------------
# AIOpsLab integration
# ------------------------------------------------------------------
AIOPSLAB_DIR="/absolute/path/to/AIOpsLab"
RESULTS_PATH="results"

# ------------------------------------------------------------------
# Logging / debug
# ------------------------------------------------------------------
LOG_LEVEL="INFO"
DEBUG="false"



